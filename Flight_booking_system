class SeatNotAvailableError(Exception):
    pass

class InvalidPassengerError(Exception):
    pass

class PaymentFailedError(Exception):
    pass


class FlightBookingSystem:

    def __init__(self):
        self.seats = 5
        self.bookings = []

    def search_flights(self):
        print("\nAvailable Flight: AI202")
        print("Route: Delhi -> Mumbai")
        print("Available Seats:", self.seats)

    def book_ticket(self):
        try:
            name = input("Enter passenger name: ")
            payment = input("Enter payment status (success/fail): ")

            if name.strip() == "":
                raise InvalidPassengerError("Passenger details are invalid")

            if self.seats <= 0:
                raise SeatNotAvailableError("No seats available")

            if payment.lower() != "success":
                raise PaymentFailedError("Payment transaction failed")

            self.seats -= 1
            self.bookings.append(name)

            print("Ticket booked successfully for", name)

        except InvalidPassengerError as e:
            print("Error:", e)

        except SeatNotAvailableError as e:
            print("Error:", e)

        except PaymentFailedError as e:
            print("Error:", e)

    def cancel_ticket(self):
        try:
            name = input("Enter passenger name to cancel ticket: ")

            if name not in self.bookings:
                raise Exception("Booking not found")

            self.bookings.remove(name)
            self.seats += 1

            print("Ticket cancelled successfully")

        except Exception as e:
            print("Error:", e)


system = FlightBookingSystem()

while True:
    print("\n--- Flight Booking System ---")
    print("1. Search Flight")
    print("2. Book Ticket")
    print("3. Cancel Ticket")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        system.search_flights()

    elif choice == "2":
        system.book_ticket()

    elif choice == "3":
        system.cancel_ticket()

    elif choice == "4":
        print("Thank you for using the system")
        break

    else:
        print("Invalid choice")