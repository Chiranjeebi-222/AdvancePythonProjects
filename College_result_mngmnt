class Student:
    def __init__(self, name, marks):
        self.name = name
        self.marks = marks

    def gpa(self):
        avg = sum(self.marks)/len(self.marks)
        print("GPA:", round(avg/10,2))


name = input("Enter student name: ")
marks = []

for i in range(3):
    m = int(input("Enter mark: "))
    marks.append(m)

s = Student(name, marks)
s.gpa()